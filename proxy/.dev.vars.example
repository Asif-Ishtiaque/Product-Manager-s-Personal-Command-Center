# Copy this file to ".dev.vars" (same folder) and fill in YOUR values.
FRONTEND_URL=http://localhost:51427
# .dev.vars is gitignored — your tokens stay on your machine, never committed.

JIRA_SITE=yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_TOKEN=your-atlassian-api-token
JIRA_PROJECT=PAY

# optional — enables the sprint widget
JIRA_BOARD_ID=
JIRA_POINTS_FIELD=

FIGMA_TOKEN=your-figma-personal-access-token
FIGMA_FILES=ABC123xyz,DEF456uvw

# optional — ClickUp (scaffolded). Leave blank to keep dormant.
# Token: ClickUp → Settings → Apps → API Token (pk_...). Team id is in the URL.
CLICKUP_TOKEN=
CLICKUP_TEAM=

# optional — Slack (scaffolded). Leave blank to keep dormant.
# User/bot token (xoxp-/xoxb-) with search:read for mentions.
SLACK_TOKEN=

# optional — restrict who can read the proxy (defaults to *)
ALLOW_ORIGIN=*

# optional — Bearer token gate on the proxy. The dashboard's passwordless
# login is client-side; set this if you also want to lock the proxy itself.
ACCESS_TOKEN=
